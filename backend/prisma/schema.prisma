generator client {
  provider = "prisma-client-js"
}

generator fabbrica {
  provider = "prisma-fabbrica"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id          String       @id @default(uuid())
  name        String
  email       String?      @unique
  password    String?
  number      String?
  role        String
  image      String?
  permissions Permissions?
  status      String       @default("active")
  createdAt   DateTime     @default(now()) @db.Timestamp(6)

  raffle             Raffles[]
  tickets            Tickets[]
  ticketReservations TicketReservations[]

  orders         Orders[] @relation("OrderUser")
  assistedOrders Orders[] @relation("OrderAssistant")
}

model Permissions {
  id                   String   @id @default(uuid())
  userId               String   @unique
  manageRaffles        Boolean? @default(false)
  manageSellers        Boolean? @default(false)
  manageTickets        Boolean? @default(false)
  manageChatbot        Boolean? @default(false)
  managePaymentMethods Boolean? @default(false)
  manageCustomers      Boolean? @default(false)
  manageOrders         Boolean? @default(false)

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Raffles {
  id              String   @id @default(uuid())
  name            String
  description     String?
  image           String?
  pricePeerTicket Int
  initialAmount   Int
  accumulated     Int      @default(0)
  subscribers     Int      @default(0)
  visibility      String   @default("public")
  status          String   @default("ongoing")
  createdBy       String
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  endsAt          DateTime

  user               Users                 @relation(fields: [createdBy], references: [id])
  orders             Orders[]
  ticketReservations TicketReservations[]
  tickets            Tickets[]
  winnerNumbers      RaffleWinnerNumbers[]
}

model RaffleWinnerNumbers {
  id        String   @id @default(uuid())
  serial    String
  raffleId  String
  createdAt DateTime @default(now()) @db.Timestamp(6)

  raffle Raffles @relation(fields: [raffleId], references: [id], onDelete: Cascade)
}

model Orders {
  id            String    @id @default(uuid())
  userId        String
  raffleId      String
  total         Int
  quantity      Int
  status        String
  paymentMethod String?
  transactionId String?
  assistedBy    String
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  purchasedAt   DateTime?

  user               Users                @relation("OrderUser", fields: [userId], references: [id])
  assistant          Users                @relation("OrderAssistant", fields: [assistedBy], references: [id])
  raffle             Raffles              @relation(fields: [raffleId], references: [id])
  ticketReservations TicketReservations[]
  tickets            Tickets[]
}

model TicketReservations {
  id        String @id @default(uuid())
  serial    String
  userId    String
  raffleId  String
  orderId   String
  expiresAt String

  user   Users   @relation(fields: [userId], references: [id])
  raffle Raffles @relation(fields: [raffleId], references: [id])
  order  Orders  @relation(fields: [orderId], references: [id])
}

model Tickets {
  id       String   @id @default(uuid())
  serial   String
  price    Int
  userId   String
  raffleId String
  orderId  String
  createdAt DateTime @default(now()) @db.Timestamp(6)

  user   Users   @relation(fields: [userId], references: [id])
  raffle Raffles @relation(fields: [raffleId], references: [id])
  order  Orders  @relation(fields: [orderId], references: [id])
}

model PaymentProviders {
  id            String  @id @default(uuid())
  name          String
  clientId  String
  clientSecret  String
}

model Chatbots {
  id    String @id
  name  String
  image Bytes
}
