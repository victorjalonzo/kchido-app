generator client {
  provider = "prisma-client-js"
}

generator fabbrica {
  provider = "prisma-fabbrica"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id            String   @id @default(uuid())
  shortId       String
  name          String
  country       String?
  state         String?
  email         String?  @unique
  password      String?
  number        String?
  contactNumber String?
  role          String
  image         String?
  status        String   @default("active")
  creatorId     String?  
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  creator       Users?   @relation("UserCreator", fields: [creatorId], references: [id])
  createdUsers  Users[]  @relation("UserCreator")

  permissions Permissions?
  
  rafflesCreated    Raffles[]  @relation("RaffleCreator")
  rafflesJoined     Raffles[]  @relation("RaffleParticipants")

  tickets            Tickets[]
  ticketReservations TicketReservations[]

  orders         Orders[] @relation("OrderUser")
  assistedOrders Orders[] @relation("OrderAssistant")
  tasks          Tasks[]
  subTasks       SubTasks[]
}


model Permissions {
  id                   String   @id @default(uuid())
  userId               String   @unique
  manageRaffles        Boolean? @default(false)
  manageSellers        Boolean? @default(false)
  manageTickets        Boolean? @default(false)
  manageChatbot        Boolean? @default(false)
  managePaymentMethods Boolean? @default(false)
  manageCustomers      Boolean? @default(false)
  manageOrders         Boolean? @default(false)

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Raffles {
  id              String   @id @default(uuid())
  shortId         String 
  name            String
  description     String?
  image           String?
  pricePeerTicket Int
  initialAmount   Int
  accumulated     Int      @default(0)
  subscribers     Int      @default(0)
  visibility      String   @default("public")
  status          String   @default("ongoing")
  creatorId       String
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  endsAt          DateTime

  creator            Users      @relation("RaffleCreator", fields: [creatorId], references: [id])
  participants       Users[]    @relation("RaffleParticipants")
  
  orders             Orders[]
  ticketReservations TicketReservations[]
  tickets            Tickets[]
  winnerNumbers      RaffleWinnerNumbers[]
  tasks Tasks[]
}

model RaffleWinnerNumbers {
  id        String   @id @default(uuid())
  serial    String
  raffleId  String
  createdAt DateTime @default(now()) @db.Timestamp(6)

  raffle Raffles @relation(fields: [raffleId], references: [id], onDelete: Cascade)
}

model Orders {
  id            String    @id @default(uuid())
  shortId       String 
  userId        String
  raffleId      String
  total         Int
  quantity      Int
  status        String
  paymentMethod String?
  transactionId String?
  assistedBy    String
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  purchasedAt   DateTime?

  user               Users                @relation("OrderUser", fields: [userId], references: [id])
  assistant          Users                @relation("OrderAssistant", fields: [assistedBy], references: [id])
  raffle             Raffles              @relation(fields: [raffleId], references: [id])
  ticketReservations TicketReservations[]
  tickets            Tickets[]
  tasks Tasks[]
}

model TicketReservations {
  id        String @id @default(uuid())
  serial    String
  userId    String
  raffleId  String
  orderId   String
  expiresAt DateTime

  user   Users   @relation(fields: [userId], references: [id])
  raffle Raffles @relation(fields: [raffleId], references: [id])
  order  Orders  @relation(fields: [orderId], references: [id])
}

model Tickets {
  id       String   @id @default(uuid())
  shortId  String 
  serial   String
  price    Int
  userId   String
  raffleId String
  orderId  String
  receiptPath String? 
  createdAt DateTime @default(now()) @db.Timestamp(6)

  user   Users   @relation(fields: [userId], references: [id])
  raffle Raffles @relation(fields: [raffleId], references: [id])
  order  Orders  @relation(fields: [orderId], references: [id])
  
  subTasks SubTasks[]
}

model PaymentProviders {
  name          String @unique
  clientId  String
  clientSecret  String
}

model ChatbotConfigurations {
  id String @id
  isOn Boolean @default(true)
  adminNumber String?
  whatsAppGroupId String?
}

model Tasks {
  id String @id() @default(uuid())
  type String
  status String
  retries Int @default(0)
  description String?
  orderId String?
  raffleId String?
  customerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  customer Users? @relation(fields: [customerId], references: [id])
  raffle Raffles? @relation(fields: [raffleId], references: [id])
  order Orders?  @relation(fields: [orderId], references: [id])

  subTasks SubTasks[]
}

model SubTasks {
  id String @id() @default(uuid())
  taskId String
  customerId String
  status String
  retries Int @default(0)
  ticketId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  task Tasks @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customer Users? @relation(fields: [customerId], references: [id], onDelete: NoAction)
  ticket Tickets? @relation(fields: [ticketId], references: [id], onDelete: NoAction)
}